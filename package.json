{
  "name": "vitalis---medical-dating",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "type-check": "tsc --noEmit",
    "lint:secrets": "grep -rE '(password|secret|api.key|service.role).*=' src/ --include='*.ts' --include='*.tsx' -l || true",
    "test:integration": "vitest run tests/integration/",
    "test:e2e:smoke": "playwright test e2e/smoke/",
    "test:e2e:a11y": "playwright test e2e/a11y/ --project=a11y-chromium",
    "test:e2e:visual": "playwright test e2e/visual/ --project=visual-desktop-light --project=visual-desktop-dark --project=visual-mobile-light",
    "test:e2e:responsive": "playwright test e2e/responsive/ --project=responsive-320 --project=responsive-375 --project=responsive-768 --project=responsive-1440",
    "test:e2e:perf": "playwright test e2e/performance/ --project=performance-desktop --project=performance-mobile",
    "test:e2e:update-snapshots": "playwright test e2e/visual/ --update-snapshots",
    "lint:tokens": "node scripts/design-token-lint.mjs",
    "lint:tokens:strict": "node scripts/design-token-lint.mjs --strict",
    "sweep:premium": "node scripts/premium-visual-sweep.mjs",
    "sweep:premium:verbose": "node scripts/premium-visual-sweep.mjs --verbose",
    "lhci:run": "lhci autorun",
    "prepare": "husky install"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/react": "^10.38.0",
    "@stripe/stripe-js": "^8.7.0",
    "@supabase/supabase-js": "^2.95.3",
    "firebase": "^12.9.0",
    "framer-motion": "^12.34.1",
    "lucide-react": "^0.563.0",
    "mixpanel-browser": "^2.74.0",
    "posthog-js": "^1.343.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@lhci/cli": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@playwright/test": "^1.58.2",
    "@react-native/assets-registry": "^0.84.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "expo-constants": "^18.0.13",
    "expo-device": "^8.0.10",
    "expo-notifications": "^0.32.16",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}